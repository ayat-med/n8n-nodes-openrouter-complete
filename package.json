{
	"name": "n8n-nodes-openrouter-complete",
	"version": "1.0.1",
	"description": "n8n community node for OpenRouter — send prompts to 200+ AI models including GPT-4o, Claude, Gemini, and Llama.",
	"license": "MIT",
	"homepage": "https://github.com/ayat-med/n8n-nodes-openrouter-complete",
	"keywords": [
		"n8n-community-node",
		"n8n-community-node-package",
		"n8n",
		"n8n-nodes",
		"github",
		"github-issues",
		"openrouter",
		"ai",
		"llm",
		"automation"
	],
	"author": {
		"name": "Ayatullah Ayat",
		"email": "ayatuallah@mediusware.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ayat-med/n8n-nodes-openrouter-complete.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [
			"dist/credentials/OpenRouterApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/OpenRouter/OpenRouter.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
